{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.nationalarchives.gov.uk/wagtail/pages.schema.json",
  "title": "Page list",
  "description": "A list of pages in Wagtail",
  "type": "object",
  "properties": {
    "meta": {
      "description": "Metadata about pages in Wagtail",
      "type": "object",
      "properties": {
        "total_count": {
          "description": "The total number of items in the page listings",
          "type": "integer"
        }
      },
      "required": ["total_count"]
    },
    "items": {
      "description": "The items in the page listings",
      "type": "array",
      "items": {
        "id": {
          "description": "The ID of the page",
          "type": "integer"
        },
        "title": {
          "description": "The title of the page",
          "type": "string"
        },
        "short_title": {
          "description": "The short title of the page",
          "type": ["string", "null"]
        },
        "page_path": {
          "description": "The path of the page",
          "type": "string"
        },
        "url": {
          "description": "The URL of the page",
          "type": "string"
        },
        "full_url": {
          "description": "The full URL of the page",
          "type": "string"
        },
        "type": {
          "description": "The type of the page",
          "type": "string"
        },
        "type_label": {
          "description": "The label of the page type",
          "type": ["string", "null"]
        },
        "teaser_text": {
          "description": "The teaser text of the page",
          "type": "string"
        },
        "teaser_image": {
          "description": "The teaser image of the page",
          "type": ["object", "null"],
          "$ref": "https://www.nationalarchives.gov.uk/wagtail/image-rendition.schema.json"
        },
        "first_published_at": {
          "description": "The first published date of the page",
          "type": "string",
          "format": "date-time"
        },
        "last_published_at": {
          "description": "The last published date of the page",
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "title",
        "page_path",
        "url",
        "full_url",
        "type",
        "teaser_text",
        "first_published_at",
        "last_published_at"
      ]
    },
    "uniqueItems": true
  },
  "required": ["meta", "items"]
}
